<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.CheckMenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1280.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.targol.mine.ui.MainWindowController">
	<children>
		<MenuBar VBox.vgrow="NEVER">
			<menus>
				<Menu mnemonicParsing="false" text="%MainWindow.mnu_game">
					<items>
						<MenuItem mnemonicParsing="false" onAction="#newGame" text="%MainWindow.mnu_game.itm_new" />
						<SeparatorMenuItem mnemonicParsing="false" />
                  <Menu mnemonicParsing="false" text="%MainWindow.mnu_game.itm_theme">
                    <items>
                        <CheckMenuItem fx:id="mnuitm_them_dark" mnemonicParsing="false" text="Unspecified Action" />
                        <CheckMenuItem fx:id="mnuitm_them_grey" mnemonicParsing="false" text="Unspecified Action" />
                        <CheckMenuItem fx:id="mnuitm_them_sunny" mnemonicParsing="false" text="Unspecified Action" />
                        <CheckMenuItem fx:id="mnuitm_them_iceberg" mnemonicParsing="false" text="Unspecified Action" />
                    </items>
                  </Menu>
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" onAction="#showAbout" text="%MainWindow.mnu_game.itm_about" />
						<MenuItem mnemonicParsing="false" onAction="#quit" text="%MainWindow.mnu_game.itm_quit" />
					</items>
				</Menu>
			</menus>
		</MenuBar>
		<BorderPane VBox.vgrow="ALWAYS" xmlns:fx="http://javafx.com/fxml">
			<center>
				<ScrollPane fx:id="scrollPane" hbarPolicy="ALWAYS" vbarPolicy="ALWAYS">
					<Group fx:id="group">
						<StackPane fx:id="contentPane">
						</StackPane>
					</Group>
				</ScrollPane>
			</center>
			<top>
				<FlowPane alignment="CENTER" columnHalignment="CENTER" prefHeight="50.0" prefWidth="200.0" BorderPane.alignment="CENTER">
					<children>
						<Label text="%MainWindow.nbMines" />
						<Label fx:id="nbMinesLeft" text="000">
							<padding>
								<Insets left="10.0" right="20.0" />
							</padding>
							<font>
								<Font name="System Bold" size="26.0" />
							</font>
						</Label>
						<Label text="%MainWindow.time" />
						<Label fx:id="timeElapsed" text="000">
							<FlowPane.margin>
								<Insets left="10.0" />
							</FlowPane.margin>
							<font>
								<Font name="System Bold" size="26.0" />
							</font>
						</Label>
					</children>
				</FlowPane>
			</top>
		</BorderPane>
	</children>
</VBox>
