<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<DialogPane prefHeight="500" prefWidth="500" stylesheets="@../../style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

	<buttonTypes>
		<ButtonType fx:id="okButtonType" buttonData="OK_DONE" text="%Generic.dialog.Ok" />
	</buttonTypes>
   <content>
      <BorderPane>
         <center>
            <ImageView fx:id="imageView" fitHeight="313.0" fitWidth="500.0" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER">
            </ImageView>
         </center>
         <bottom>
            <Label fx:id="resultTextField" text="Test" textAlignment="CENTER" wrapText="true" BorderPane.alignment="CENTER">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
         </bottom>
      </BorderPane>
   </content>

</DialogPane>
