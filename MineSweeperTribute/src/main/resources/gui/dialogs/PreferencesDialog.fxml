<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<DialogPane prefWidth="500" prefHeight="500" stylesheets="@../../style/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

	<buttonTypes>
		<ButtonType fx:id="okButtonType" buttonData="OK_DONE" text="%Generic.dialog.Ok" />
	</buttonTypes>
	<content>
		<VBox>
			<GridPane hgap="5" vgap="5">

				<Label text="%Dialog.prefs.theme" GridPane.columnIndex="0" GridPane.rowIndex="1" />
				<ChoiceBox fx:id="themeChoiceBox" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="2" />

				<columnConstraints>
					<ColumnConstraints />
					<ColumnConstraints hgrow="ALWAYS" />
					<ColumnConstraints />
				</columnConstraints>
				<rowConstraints>
					<RowConstraints />
					<RowConstraints />
				</rowConstraints>
			</GridPane>
		</VBox>
	</content>

</DialogPane>
